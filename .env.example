# Supabase — crea progetto su https://supabase.com
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Prevendita — Payment Link IDs (da creare su dashboard.stripe.com/payment-links)
# Lascia vuoti finché non hai i listini: la landing funziona comunque in modalità "lista attesa"
STRIPE_PRICE_BASE=price_xxxxx
STRIPE_PRICE_PLUS=price_xxxxx
STRIPE_PRICE_PREMIUM=price_xxxxx
STRIPE_PRICE_PERSONAL=price_xxxxx

# URL del sito (per success/cancel redirect Stripe)
PUBLIC_SITE_URL=https://lumefitness.it
