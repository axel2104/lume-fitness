---
import { CLUBS } from '../lib/data';
---

<footer class="border-t border-white/[0.06] bg-dark-900 mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="15" stroke="#c2ff00" stroke-width="1.5"/>
            <path d="M16 6 L16 26 M8 12 L24 12 M8 20 L24 20" stroke="#c2ff00" stroke-width="2" stroke-linecap="round"/>
            <circle cx="16" cy="16" r="3" fill="#c2ff00"/>
          </svg>
          <span class="font-display font-bold text-lg">
            <span class="text-lume-300">LUME</span>
            <span class="text-white/50 font-light ml-1 text-sm">FITNESS</span>
          </span>
        </a>
        <p class="text-white/40 text-sm leading-relaxed max-w-xs">
          Due club, un'unica filosofia: aiutarti a diventare la versione migliore di te stesso.
        </p>
        <div class="flex gap-3 mt-5">
          <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram"
             class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-lume-300 hover:border-lume-300/40 transition-colors">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook"
             class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-lume-300 hover:border-lume-300/40 transition-colors">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Link -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-4">Esplora</h3>
        <ul class="space-y-2">
          {[['Corsi & Orari', '/corsi'], ['Abbonamenti', '/abbonamenti'], ['Prenotazione', '/prenota'], ['Blog & News', '/blog']].map(([label, href]) => (
            <li><a href={href} class="text-white/60 text-sm hover:text-lume-300 transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Sedi -->
      {CLUBS.map(club => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-4">{club.name}</h3>
          <ul class="space-y-2 text-sm text-white/50">
            <li>{club.address}</li>
            <li><a href={`tel:${club.phone.replace(/\s/g,'')}`} class="hover:text-lume-300 transition-colors">{club.phone}</a></li>
            <li><a href={`mailto:${club.email}`} class="hover:text-lume-300 transition-colors">{club.email}</a></li>
            <li class="pt-1 text-white/30 text-xs">Lun–Ven: {club.hours.weekdays}</li>
            <li class="text-white/30 text-xs">Sab: {club.hours.saturday}</li>
            <li class="text-white/30 text-xs">Dom: {club.hours.sunday}</li>
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-6 border-t border-white/[0.05] flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-white/25 text-xs">© {new Date().getFullYear()} Lume Fitness Club. Tutti i diritti riservati.</p>
      <div class="flex gap-5">
        {[['Privacy Policy', '/privacy'], ['Cookie Policy', '/cookie'], ['Note legali', '/note-legali']].map(([label, href]) => (
          <a href={href} class="text-white/25 text-xs hover:text-white/50 transition-colors">{label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
