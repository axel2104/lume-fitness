---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ClubsMap from '../components/react/ClubsMap';
import { CLUBS, COURSES, MEMBERSHIP_PLANS } from '../lib/data';

const featuredCourses = COURSES.slice(0, 4);
const featuredPlan = MEMBERSHIP_PLANS.find(p => p.highlighted)!;
---

<Layout title="Home" description="Lume Fitness Club — Macerata e Montecassiano. Allenati al massimo con corsi, personal trainer e strutture di alto livello.">
  <Header />

  <main>
    <!-- ═══════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 sm:px-6">
      <!-- Background glow -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-lume-300/5 blur-[120px]"></div>
        <div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full bg-lume-300/3 blur-[100px]"></div>
      </div>

      <!-- Grid decorativo -->
      <div class="absolute inset-0 pointer-events-none opacity-[0.03]" aria-hidden="true"
           style="background-image: linear-gradient(rgba(255,255,255,.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.5) 1px, transparent 1px); background-size: 60px 60px;">
      </div>

      <div class="relative z-10 max-w-5xl mx-auto text-center pt-24">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-lume-300/30 bg-lume-300/5 text-lume-300 text-sm font-medium mb-8 animate-fade-in">
          <span class="w-1.5 h-1.5 rounded-full bg-lume-300 animate-pulse"></span>
          2 Sedi · Macerata & Montecassiano
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold text-5xl sm:text-7xl md:text-8xl leading-[0.95] tracking-tight mb-6 animate-fade-up">
          Forgia<br/>
          <span class="text-lume-300">il tuo</span><br/>
          limite.
        </h1>

        <p class="text-white/50 text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed animate-fade-up" style="animation-delay:150ms">
          Club premium con strutture all'avanguardia, istruttori certificati e una community che ti spinge oltre.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up" style="animation-delay:250ms">
          <a href="/prenota" class="btn-primary text-base px-8 py-3.5">
            Inizia gratis
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/abbonamenti" class="btn-outline text-base px-8 py-3.5">
            Vedi abbonamenti
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 sm:gap-12 mt-20 pt-10 border-t border-white/[0.06] animate-fade-up" style="animation-delay:400ms">
          {[
            ['2', 'Club attivi'],
            ['500+', 'Membri'],
            ['30+', 'Corsi/sett.'],
          ].map(([num, label]) => (
            <div>
              <div class="font-display font-bold text-3xl sm:text-4xl text-white">{num}</div>
              <div class="text-white/40 text-sm mt-1">{label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-40" aria-hidden="true">
        <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
          <path d="M12 5v14M5 12l7 7 7-7" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SEDI
    ═══════════════════════════════════════════════ -->
    <section class="py-24 px-4 sm:px-6">
      <div class="mx-auto max-w-7xl">
        <div class="text-center mb-14 reveal">
          <p class="section-label mb-3">Le nostre sedi</p>
          <h2 class="section-title">Due club,<br/>una filosofia.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {CLUBS.map((club, i) => (
            <a
              href={`/sedi/${club.slug}`}
              class:list={[
                'card group relative overflow-hidden p-8 cursor-pointer',
                i === 0 ? 'reveal-left' : 'reveal-right'
              ]}
            >
              <!-- Hover glow -->
              <div class="absolute inset-0 bg-lume-300/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
              <div class="absolute top-0 left-0 w-1 h-full bg-lume-300 opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>

              <div class="relative z-10">
                <div class="flex items-start justify-between mb-6">
                  <div>
                    <p class="section-label mb-1">{i === 0 ? 'Club principale' : 'Club'}</p>
                    <h3 class="font-display font-bold text-2xl text-white">{club.name}</h3>
                  </div>
                  <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center group-hover:border-lume-300/40 group-hover:bg-lume-300/5 transition-all duration-300">
                    <svg width="16" height="16" fill="none" viewBox="0 0 16 16">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>

                <p class="text-white/50 text-sm mb-6 flex items-center gap-2">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/></svg>
                  {club.address}
                </p>

                <ul class="grid grid-cols-2 gap-2">
                  {club.features.map(f => (
                    <li class="flex items-center gap-2 text-sm text-white/50">
                      <span class="w-1 h-1 rounded-full bg-lume-300 flex-shrink-0"></span>
                      {f}
                    </li>
                  ))}
                </ul>

                <div class="mt-6 pt-6 border-t border-white/[0.06] grid grid-cols-3 gap-4 text-xs text-white/30">
                  <div><div class="text-white/60 font-medium mb-0.5">Lun–Ven</div>{club.hours.weekdays}</div>
                  <div><div class="text-white/60 font-medium mb-0.5">Sabato</div>{club.hours.saturday}</div>
                  <div><div class="text-white/60 font-medium mb-0.5">Domenica</div>{club.hours.sunday}</div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         CORSI IN EVIDENZA
    ═══════════════════════════════════════════════ -->
    <section class="py-24 px-4 sm:px-6 bg-dark-800/30">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-14 reveal">
          <div>
            <p class="section-label mb-3">Corsi & attività</p>
            <h2 class="section-title">Allenati<br/>come vuoi.</h2>
          </div>
          <a href="/corsi" class="btn-outline text-sm hidden sm:inline-flex">Tutti i corsi</a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {featuredCourses.map((course, i) => (
            <div
              class="card p-6 reveal"
              style={`transition-delay: ${i * 80}ms`}
            >
              <div
                class="w-10 h-10 rounded-xl mb-4 flex items-center justify-center text-dark-900 font-bold text-sm"
                style={`background-color: ${course.color}`}
              >
                {course.name.slice(0,2).toUpperCase()}
              </div>
              <h3 class="font-display font-semibold text-lg mb-1">{course.name}</h3>
              <p class="text-white/40 text-sm leading-relaxed mb-4">{course.description}</p>
              <div class="flex items-center gap-3 text-xs text-white/30">
                <span>{course.duration} min</span>
                <span class="w-1 h-1 rounded-full bg-white/20"></span>
                <span>{course.level}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 sm:hidden">
          <a href="/corsi" class="btn-outline w-full justify-center">Tutti i corsi</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         ABBONAMENTO IN EVIDENZA
    ═══════════════════════════════════════════════ -->
    <section class="py-24 px-4 sm:px-6">
      <div class="mx-auto max-w-7xl">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="reveal-left">
            <p class="section-label mb-3">Abbonamenti</p>
            <h2 class="section-title mb-6">Il piano giusto<br/>per i tuoi obiettivi.</h2>
            <p class="text-white/50 leading-relaxed mb-8">
              Scegli tra i nostri piani flessibili. Se non sei sicuro, prova gratis per 3 giorni — nessuna carta richiesta.
            </p>
            <div class="flex gap-4">
              <a href="/abbonamenti" class="btn-primary">Scopri i piani</a>
              <a href="/prenota" class="btn-outline">Prova gratis</a>
            </div>
          </div>

          <!-- Featured plan card -->
          <div class="reveal-right">
            <div class="card relative p-8 border-lume-300/30 animate-glow-pulse">
              <div class="absolute -top-3 left-8">
                <span class="bg-lume-300 text-dark-900 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                  Più popolare
                </span>
              </div>
              <div class="pt-2">
                <h3 class="font-display font-bold text-2xl mb-1">{featuredPlan.name}</h3>
                <p class="text-white/40 text-sm mb-6">{featuredPlan.description}</p>
                <div class="flex items-baseline gap-2 mb-8">
                  <span class="font-display font-bold text-5xl text-white">€{featuredPlan.price}</span>
                  <span class="text-white/40 text-sm">/{featuredPlan.period}</span>
                </div>
                <ul class="space-y-3 mb-8">
                  {featuredPlan.features.map(f => (
                    <li class="flex items-center gap-3 text-sm text-white/70">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="flex-shrink-0">
                        <circle cx="8" cy="8" r="7" stroke="#c2ff00" stroke-width="1.5"/>
                        <path d="M5 8l2 2 4-4" stroke="#c2ff00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
                <a href="/abbonamenti" class="btn-primary w-full justify-center">Scegli questo piano</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         MAPPA SEDI
    ═══════════════════════════════════════════════ -->
    <section class="py-24 px-4 sm:px-6">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-10 reveal">
          <div>
            <p class="section-label mb-3">Dove siamo</p>
            <h2 class="section-title">Trovaci.</h2>
          </div>
          <div class="flex gap-3 hidden sm:flex">
            <a
              href="https://maps.google.com/?q=Piazzale+Mario+Fattorini+1,+Macerata"
              target="_blank" rel="noopener"
              class="btn-outline text-sm py-2"
            >
              Macerata →
            </a>
            <a
              href="https://maps.google.com/?q=Via+Sergio+Piermanni+3,+Montecassiano"
              target="_blank" rel="noopener"
              class="btn-outline text-sm py-2"
            >
              Montecassiano →
            </a>
          </div>
        </div>
        <div class="reveal">
          <ClubsMap client:visible />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         CTA FINALE
    ═══════════════════════════════════════════════ -->
    <section class="py-32 px-4 sm:px-6 relative overflow-hidden">
      <div class="absolute inset-0 bg-lume-300/5 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background-image: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(194,255,0,0.08), transparent);">
      </div>

      <div class="relative z-10 max-w-3xl mx-auto text-center reveal">
        <p class="section-label mb-4">Inizia oggi</p>
        <h2 class="font-display font-bold text-5xl sm:text-6xl leading-tight mb-6">
          Il momento migliore<br/>è <span class="text-lume-300">adesso</span>.
        </h2>
        <p class="text-white/50 text-lg mb-10">
          Prima sessione gratuita. Nessun impegno. Solo risultati.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/prenota" class="btn-primary text-base px-10 py-4">
            Prenota la prima sessione
          </a>
          <a href="/abbonamenti" class="btn-outline text-base px-10 py-4">
            Confronta i piani
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
