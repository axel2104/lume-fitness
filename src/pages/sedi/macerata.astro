---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { CLUBS, COURSES } from '../../lib/data';

const club = CLUBS.find(c => c.id === 'macerata')!;
const courses = COURSES.filter(c => c.club === 'macerata' || c.club === 'both');
---

<Layout title={club.name} description={`${club.name} — ${club.address}. Sala pesi, corsi di gruppo, piscina e SPA.`}>
  <Header />

  <main class="pt-24">
    <!-- Hero sede -->
    <section class="py-16 px-4 sm:px-6 relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
           style="background: radial-gradient(ellipse 60% 50% at 30% 50%, rgba(194,255,0,0.06), transparent)">
      </div>
      <div class="mx-auto max-w-7xl relative">
        <div class="reveal">
          <p class="section-label mb-3">Club principale</p>
          <h1 class="section-title mb-4">{club.name}</h1>
          <p class="text-white/50 text-lg mb-8">{club.address}</p>
          <div class="flex gap-4">
            <a href={`tel:${club.phone.replace(/\s/g,'')}`} class="btn-outline text-sm">{club.phone}</a>
            <a href="/prenota" class="btn-primary text-sm">Prenota una visita</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-16 px-4 sm:px-6">
      <div class="mx-auto max-w-7xl">
        <div class="grid md:grid-cols-3 gap-5">
          {club.features.map((feature, i) => (
            <div class="card p-6 reveal" style={`transition-delay: ${i * 60}ms`}>
              <div class="w-8 h-8 rounded-lg bg-lume-300/10 flex items-center justify-center mb-4">
                <span class="text-lume-300 text-sm font-bold">{(i+1).toString().padStart(2,'0')}</span>
              </div>
              <p class="font-medium text-white">{feature}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Orari -->
    <section class="py-16 px-4 sm:px-6 bg-dark-800/30">
      <div class="mx-auto max-w-7xl">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="reveal-left">
            <p class="section-label mb-3">Orari</p>
            <h2 class="font-display font-bold text-3xl mb-8">Quando siamo aperti</h2>
            <div class="space-y-3">
              {[
                ['Lunedì – Venerdì', club.hours.weekdays],
                ['Sabato', club.hours.saturday],
                ['Domenica', club.hours.sunday],
              ].map(([day, hours]) => (
                <div class="flex justify-between items-center py-3 border-b border-white/[0.05]">
                  <span class="text-white/60">{day}</span>
                  <span class="font-medium text-white">{hours}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="reveal-right">
            <div class="card p-7">
              <h3 class="font-display font-bold text-xl mb-4">Contatti</h3>
              <div class="space-y-3 text-sm">
                <a href={`tel:${club.phone.replace(/\s/g,'')}`} class="flex items-center gap-3 text-white/60 hover:text-white transition-colors">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.18 19.79 19.79 0 01.07 9.54 2 2 0 012 7.36V4.36A2 2 0 014 2.36c.06 0 .12 0 .18.01a16 16 0 014.67 1.57 15.74 15.74 0 015.64 5.64 16 16 0 011.57 4.67A2 2 0 0118 16.18l.08.01h.84a2 2 0 012 2z" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/></svg>
                  {club.phone}
                </a>
                <a href={`mailto:${club.email}`} class="flex items-center gap-3 text-white/60 hover:text-white transition-colors">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 4h16v16H4V4zm0 0l8 8 8-8" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/></svg>
                  {club.email}
                </a>
              </div>
              <div class="mt-6">
                <a href="/prenota" class="btn-primary w-full justify-center text-sm">Prenota una visita gratuita</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Corsi disponibili -->
    <section class="py-16 px-4 sm:px-6">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-10 reveal">
          <div>
            <p class="section-label mb-2">Attività</p>
            <h2 class="font-display font-bold text-3xl">Corsi disponibili</h2>
          </div>
          <a href="/corsi" class="btn-outline text-sm hidden sm:inline-flex">Orari completi</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {courses.slice(0, 8).map((course, i) => (
            <div class="card p-5 reveal" style={`transition-delay: ${i * 60}ms`}>
              <div class="w-8 h-8 rounded-lg mb-3 flex items-center justify-center text-xs font-bold text-dark-900"
                   style={`background-color: ${course.color}`}>
                {course.name.slice(0,2).toUpperCase()}
              </div>
              <h3 class="font-semibold text-white mb-1">{course.name}</h3>
              <p class="text-white/40 text-xs">{course.duration} min · {course.level}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
